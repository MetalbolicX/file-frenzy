{
  "name": "file-frenzy",
  "version": "1.0.0",
  "description": "File and folder rename script",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "main": "./dist/index.mjs",
  "exports": {
    "imports": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "type": "module",
  "scripts": {
    "start": "echo \"Hello world\"",
    "build": "tsdown",
    "res:build": "rescript",
    "res:dev": "rescript watch",
    "res:clean": "rescript clean",
    "rolldown:build": "rolldown -c"
  },
  "author": {
    "name": "José Martínez Santana"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/MetalbolicX/file-frenzy.git"
  },
  "bugs": {
    "url": "https://github.com/MetalbolicX/file-frenzy/issues"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rolldown": "1.0.0-rc.9",
    "tsdown": "0.20.0-beta.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@rescript/runtime": "^12.2.0",
    "rescript": "^12.2.0"
  }
}
